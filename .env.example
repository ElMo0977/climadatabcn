# ==============================================
# Meteo BCN - Environment Variables Example
# ==============================================
# Copy this file to .env and adjust only what you need.

# Optional proxy base URL for Socrata requests.
# Leave empty to call Transparencia Catalunya directly from the browser.
VITE_API_PROXY_URL=

# Provider-level diagnostics for XEMA fetches and daily/subdaily summaries.
# Enabled only in development. Accepted values: true, 1, yes, on
VITE_DEBUG_XEMA=false

# Final dataset audit in browser console.
# Logs request params, stats, timestamps and stores a snapshot in window.__DATA_DEBUG_SNAPSHOT.
# Uncomment to enable:
# VITE_DEBUG_DATA=1

# Internal config parsed by src/config/env.ts.
# The current runtime does not branch on this variable, so keep it unset unless
# you are validating env parsing behavior explicitly.
# VITE_DATA_MODE=live
